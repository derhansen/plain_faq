plugin.tx_plainfaq {
    view {
        templateRootPaths.10 = {$plugin.tx_plainfaq.view.templateRootPath ?? $plain_faq.view.templateRootPath}
        partialRootPaths.10 = {$plugin.tx_plainfaq.view.partialRootPath ?? $plain_faq.view.partialRootPath}
        layoutRootPaths.10 = {$plugin.tx_plainfaq.view.layoutRootPath ?? $plain_faq.view.layoutRootPath}
    }
    settings {
        orderFieldAllowed = uid,question,sorting
    }
}